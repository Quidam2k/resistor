# API Keys — copy this to .env and fill in your keys
# .env is gitignored so your credentials stay private

# Congress.gov API (free) — sign up at api.congress.gov/sign-up
CONGRESS_API_KEY=

# Notifyre (fax delivery) — sign up at notifyre.com, ~$0.03/page
NOTIFYRE_API_KEY=

# Email (SMTP) — for sending to state/local reps with direct email
SMTP_FROM_ADDRESS=
SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
